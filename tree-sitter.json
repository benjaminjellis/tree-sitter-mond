{
  "grammars": [
    {
      "name": "mond",
      "camelcase": "Mond",
      "scope": "source.mond",
      "path": ".",
      "file-types": [
        "mond"
      ],
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm",
      "locals": "queries/locals.scm",
      "tags": "queries/tags.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Mond language",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-mond"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
